# SignalLens local environment template
#
# Copy to `.env` for Docker Compose/local development:
#   cp .env.example .env
#
# Do not commit real secrets.

# ── Docker Compose ports ─────────────────────────────────────────────────────
# Host ports for local services. Change these if the defaults are occupied.
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Runtime mode ─────────────────────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development

# When true, read APIs hide seeded mock risk events/summaries and show only
# real-ingested rows. Local compose defaults to true.
REAL_INGESTION_MODE=true

# Backend startup seeding. In docker-compose.yml this is currently set directly
# to "true" for the backend container so base companies/topics exist locally.
SEED_ON_START=true

# ── Core service URLs ────────────────────────────────────────────────────────
# Use these host URLs when running backend outside Docker.
DATABASE_URL=postgresql+psycopg://signallens:signallens@localhost:5432/signallens
REDIS_URL=redis://localhost:6379/0

# Comma-separated allowed browser origins for the FastAPI CORS middleware.
CORS_ORIGINS=http://localhost:3000

# JWT signing key for auth. Replace for any shared/staging/prod environment.
SECRET_KEY=dev-secret-change-in-prod

# ── Model providers ──────────────────────────────────────────────────────────
# Required to run extraction/summarization tasks.
ANTHROPIC_API_KEY=
ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-4-6
ANTHROPIC_SUMMARY_MODEL=claude-haiku-4-5-20251001

# Required for semantic embeddings/search.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Optional integrations ────────────────────────────────────────────────────
# ClickHouse DSN for analytics sync. Leave empty to disable.
CLICKHOUSE_URL=

# Sentry DSN for backend error reporting. Leave empty to disable.
SENTRY_DSN=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Alert delivery ───────────────────────────────────────────────────────────
# Fallback webhook used when an alert rule does not specify a webhook URL.
ALERT_WEBHOOK_URL=

# SMTP delivery. When SMTP_HOST is empty, email alerts are logged only.
ALERT_FROM_EMAIL=alerts@signallens.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ── Frontend public env ──────────────────────────────────────────────────────
# These are used by Next.js. In Docker Compose they are derived from
# BACKEND_PORT and REAL_INGESTION_MODE, but they are useful when running the
# frontend directly with npm.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_REAL_INGESTION_MODE=true
